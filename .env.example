# =============================================
# DramaForge v2.0 — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# ── laozhang.ai API Gateway (required) ──
LAOZHANG_API_KEY=your-api-key-here
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./storage/dramaforge.db

# ── Redis (native deployment usually uses 127.0.0.1; Docker uses redis) ──
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-this-to-a-random-string
SECRET_KEY=change-this-to-a-random-string

# ── Email verification login ──
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Debug ──
DEBUG=true
